<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Check_ProcessStage</fullName>
    <active>true</active>
    <errorConditionFormula>AND(ISBLANK(FinancialService__c),
ISPICKVAL( StageName , &quot;Closed Won&quot;))</errorConditionFormula>
    <errorMessage>Non puó essere dichiarata chiusa e vinta con il Financial Service a zero.</errorMessage>
</ValidationRule>
