<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>CheckTaxCode</fullName>
    <active>true</active>
    <errorConditionFormula>NOT( REGEX( TaxCode__c,
            &quot;^[A-Za-z0-9]{16}$&quot;))</errorConditionFormula>
    <errorDisplayField>TaxCode__c</errorDisplayField>
    <errorMessage>Deve essere composto da 16 caratteri alfanumerici</errorMessage>
</ValidationRule>
